# Local Claude Code config & per-developer state
.claude/settings.local.json
memory-bank/activeTask.md

# IDE
.idea/
.vscode/

# Node / Electron
node_modules/
dist/
out/
# Use `build/*` (not `build/`) so the negation patterns below can re-include
# specific files — Git can't un-ignore a path whose parent directory itself
# is excluded.
build/*
# App-icon artifacts (regenerated by scripts/build-icons.mjs on brand updates)
# are committed so contributors don't need to run the script before every
# `npm run dist:*`.
!build/icon.png
!build/icon.ico
!build/icon.icns
release/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Test artifacts
coverage/
playwright-report/
test-results/
